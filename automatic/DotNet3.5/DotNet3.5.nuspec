    <title>Dot Net 3.5</title>
    <authors>Microsoft</authors>
    <projectUrl>https://dotnet.microsoft.com/en-us/download/dotnet-framework/net35-sp1</projectUrl>
    <iconUrl>https://cdn.statically.io/gh/Aurocosh/chocolatey-packages/master/automatic/DotNet3.5/img/icon.png</iconUrl>
